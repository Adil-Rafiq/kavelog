# Database (Supabase Postgres connection string)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# NextAuth
AUTH_SECRET=""           # Generate with: openssl rand -base64 32
AUTH_URL="http://localhost:3000"

# Optional: Vercel cron secret (for protecting cron endpoints)
CRON_SECRET=""

# Resend (password reset emails) — get a key at https://resend.com
RESEND_API_KEY=""
EMAIL_FROM="onboarding@resend.dev"

# Public base URL used to build reset links (defaults to request origin)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Web Push (VAPID) — powers opt-in push reminders. Generate a keypair with:
#   npx web-push generate-vapid-keys --json
# The public key must be exposed to the browser too (NEXT_PUBLIC_ copy).
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
